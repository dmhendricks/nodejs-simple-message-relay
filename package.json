{
  "name": "nodejs-simple-message-relay",
  "version": "0.2.0",
  "description": "A simple Node.js server to relay messages to Socket.IO clients",
  "license": "Apache-2.0",
  "keywords": [
    "socket.io",
    "message",
    "relay",
    "nodejs"
  ],
  "author": "Daniel M. Hendricks",
  "private": true,
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "clean": "rm -rf public/assets/css/*.css public/assets/js/*.js",
    "build:js": "node esbuild.config.js --prod",
    "watch:js": "node esbuild.config.js --watch",
    "build:css": "node build-css.js --prod",
    "watch:css": "node build-css.js --watch",
    "build": "npm run clean && npm-run-all --parallel build:js build:css",
    "dev:assets": "npm-run-all --parallel watch:js watch:css"
  },
  "dependencies": {
    "config": "^3.2.4",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "http-errors": "^2.0.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "basecss": "^0.3.2",
    "cssnano": "^7.0.6",
    "esbuild": "^0.24.2",
    "jquery": "^3.4.1",
    "nodemon": "^2.0.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.49",
    "sass": "^1.83.0",
    "sprintf-js": "^1.1.2"
  }
}
